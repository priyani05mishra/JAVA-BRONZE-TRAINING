class Solution {

    
    public boolean isPalindrome(int n) {
        int original = n;
        int reverse = 0;

        while (n > 0) {
            int digit = n % 10;
            reverse = reverse * 10 + digit;
            n = n / 10;
        }

        return original == reverse;
    }

    public boolean isPalinArray(int[] arr) {
        for (int i = 0; i < arr.length; i++) {
            
            if (!isPalindrome(arr[i])) {
                return false; 
            }
        }
        return true; 
    }
}
